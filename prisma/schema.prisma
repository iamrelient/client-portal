generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum FileCategory {
  RENDER
  DRAWING
  CAD_DRAWING
  SUPPORTING
  OTHER
}

model Company {
  id        String   @id @default(cuid())
  name      String
  domain    String   @unique
  logoPath  String?
  createdAt DateTime @default(now())
  users     User[]

  @@map("companies")
}

model User {
  id             String     @id @default(cuid())
  name           String
  email          String     @unique
  hashedPassword String
  role           Role       @default(USER)
  company        String?
  companyId      String?
  companyRef     Company?   @relation(fields: [companyId], references: [id], onDelete: SetNull)
  phone          String?
  avatarUrl      String?
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  lastLoginAt    DateTime?
  activities     Activity[]
  sessions       Session[]
  files          File[]
  projects       Project[]
  fileViews      FileView[]
  presentations  Presentation[]

  @@index([companyId])
  @@map("users")
}

model File {
  id              String   @id @default(cuid())
  name            String
  originalName    String
  size            Int
  mimeType        String
  path            String
  driveFileId     String?
  syncedFromDrive Boolean  @default(false)
  uploadedById    String
  uploadedBy      User     @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  projectId       String?
  project         Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category        FileCategory @default(OTHER)
  displayName     String?
  isCurrent       Boolean  @default(false)
  version         Int      @default(1)
  fileGroupId     String?
  createdAt       DateTime @default(now())
  fileViews             FileView[]
  presentationSections  PresentationSection[]

  @@index([uploadedById])
  @@index([projectId])
  @@index([fileGroupId])
  @@index([projectId, originalName])
  @@index([driveFileId])
  @@map("files")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Activity {
  id          String   @id @default(cuid())
  type        String
  description String
  metadata    Json?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("activities")
}

model Project {
  id               String    @id @default(cuid())
  name             String
  status           String    @default("concept")
  thumbnailPath    String?
  company          String?
  companyLogoPath  String?
  authorizedEmails String[]
  driveFolderId    String?
  lastSyncedAt     DateTime?
  createdById      String
  createdBy        User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  files            File[]
  presentations    Presentation[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("projects")
}

model FileView {
  id       String   @id @default(cuid())
  fileId   String
  file     File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  viewedAt DateTime @default(now())

  @@index([fileId])
  @@index([userId])
  @@index([viewedAt])
  @@map("file_views")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model GoogleToken {
  id           String   @id @default("singleton")
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  email        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("google_tokens")
}

model Presentation {
  id                String                  @id @default(cuid())
  projectId         String
  project           Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title             String?
  subtitle          String?
  clientLogo        String?
  clientAccentColor String?
  password          String?
  expiresAt         DateTime?
  isActive          Boolean                 @default(true)
  accessToken       String                  @unique
  watermarkEnabled  Boolean                 @default(true)
  createdById       String
  createdBy         User                    @relation(fields: [createdById], references: [id])
  sections          PresentationSection[]
  accessLogs        PresentationAccessLog[]
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([accessToken])
  @@index([projectId])
  @@map("presentations")
}

model PresentationSection {
  id              String       @id @default(cuid())
  presentationId  String
  presentation    Presentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)
  type            String
  order           Int
  fileId          String?
  file            File?        @relation(fields: [fileId], references: [id], onDelete: SetNull)
  title           String?
  description     String?
  transitionStyle String?
  metadata        Json?
  createdAt       DateTime     @default(now())

  @@index([presentationId])
  @@map("presentation_sections")
}

model PresentationAccessLog {
  id              String       @id @default(cuid())
  presentationId  String
  presentation    Presentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)
  viewerEmail     String?
  viewerName      String?
  ipAddress       String?
  userAgent       String?
  viewedAt        DateTime     @default(now())

  @@index([presentationId])
  @@map("presentation_access_logs")
}
