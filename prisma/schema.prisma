generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  STAFF
  ADMIN
}

enum FileCategory {
  RENDER
  DRAWING
  CAD_DRAWING
  SUPPORTING
  DESIGN_INSPIRATION
  OTHER
}

enum BoardType {
  INTERIOR
  EXTERIOR
}

model Company {
  id        String   @id @default(cuid())
  name      String
  domain    String   @unique
  logoPath  String?
  createdAt DateTime @default(now())
  users     User[]

  @@map("companies")
}

model User {
  id             String     @id @default(cuid())
  name           String
  email          String     @unique
  hashedPassword String
  role           Role       @default(USER)
  company        String?
  companyId      String?
  companyRef     Company?   @relation(fields: [companyId], references: [id], onDelete: SetNull)
  phone          String?
  avatarUrl      String?
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  lastLoginAt    DateTime?
  activities     Activity[]
  sessions       Session[]
  files          File[]
  projects       Project[]
  fileViews      FileView[]
  presentations  Presentation[]

  @@index([companyId])
  @@map("users")
}

model File {
  id              String   @id @default(cuid())
  name            String
  originalName    String
  size            Int
  mimeType        String
  path            String
  driveFileId     String?
  syncedFromDrive Boolean  @default(false)
  uploadedById    String
  uploadedBy      User     @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  projectId       String?
  project         Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category        FileCategory @default(OTHER)
  customCategory  String?
  displayName     String?
  notes           String?
  boardType       BoardType?
  thumbnailUrl    String?
  isCurrent       Boolean  @default(false)
  isOutdated      Boolean  @default(false)
  isPanorama      Boolean  @default(false)
  isPresentationAsset Boolean @default(false)
  // Viewer-optimized derivative — a downscaled, watermarked JPEG
  // built at upload time. Lets the presentation viewer load 4K/8K
  // panoramas as ~1–3 MB JPEGs instead of streaming 50–100 MB
  // originals through serve-time Sharp. The original Drive file is
  // never touched; viewerDriveFileId points to a sibling JPEG.
  // viewerHasWatermark records whether watermarking was baked in so
  // the asset route can fall back to the original if a presentation
  // disables watermarks after upload.
  viewerDriveFileId   String?
  viewerMimeType      String?
  viewerSize          Int?
  viewerWidth         Int?
  viewerHeight        Int?
  viewerHasWatermark  Boolean @default(false)
  // Multiresolution tile pyramid (Matterport-style). Built by
  // /api/files/[id]/generate-multires: the equirectangular source is
  // converted to 6 cube faces and sliced into a Pannellum "multires"
  // pyramid of 512px tiles (plus 1024px fallback faces), stored as
  // individual JPEGs in a per-pano Drive subfolder. The manifest maps
  // tile path ("1/f0_0", "fallback/f") → Drive file id so the tile
  // route can serve them. Lets the viewer stream only the tiles in
  // view at the detail needed — full 6K sharpness on zoom without the
  // 4096px single-texture WebGL cap, and a much faster first paint.
  multiresManifest     Json?
  multiresMaxLevel     Int?
  multiresCubeRes      Int?
  multiresTileRes      Int?
  multiresHasWatermark Boolean @default(false)
  version         Int      @default(1)
  fileGroupId     String?
  folderId        String?
  folder          ProjectFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  fileViews             FileView[]
  presentationSections  PresentationSection[]

  @@index([uploadedById])
  @@index([projectId])
  @@index([fileGroupId])
  @@index([folderId])
  @@index([projectId, originalName])
  @@index([driveFileId])
  @@map("files")
}

model ProjectFolder {
  id             String       @id @default(cuid())
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category       FileCategory
  customCategory String?
  name           String
  driveFolderId  String?
  sortOrder      Int          @default(0)
  files          File[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([projectId])
  @@index([projectId, category])
  @@unique([projectId, category, customCategory, name])
  @@map("project_folders")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Activity {
  id          String   @id @default(cuid())
  type        String
  description String
  metadata    Json?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("activities")
}

model Project {
  id               String    @id @default(cuid())
  name             String
  status           String    @default("concept")
  thumbnailPath    String?
  company          String?
  companyLogoPath  String?
  authorizedEmails String[]
  driveFolderId    String?
  lastSyncedAt     DateTime?
  deletedDriveIds  String[]  @default([])
  watermarkEnabled Boolean   @default(true)
  createdById      String
  createdBy        User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  files            File[]
  folders          ProjectFolder[]
  presentations    Presentation[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  lastActivityAt   DateTime  @default(now())

  @@map("projects")
}

model FileView {
  id       String   @id @default(cuid())
  fileId   String
  file     File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  viewedAt DateTime @default(now())

  @@index([fileId])
  @@index([userId])
  @@index([viewedAt])
  @@map("file_views")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model GoogleToken {
  id           String   @id @default("singleton")
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  email        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("google_tokens")
}

model Presentation {
  id                String                  @id @default(cuid())
  projectId         String
  project           Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title             String?
  subtitle          String?
  clientLogo        String?
  logoDisplay       String?                 @default("auto")
  logoSize          String?                 @default("medium")
  clientAccentColor String?
  password          String?
  expiresAt         DateTime?
  isActive          Boolean                 @default(true)
  accessToken       String                  @unique
  watermarkEnabled  Boolean                 @default(true)
  panoramaFloorWatermark Boolean            @default(true)
  /// Optional cover image for the 360° tour slide. When set,
  /// section-panorama renders this file (with a darkened overlay
  /// + play button + "Click to view 360° tour" prompt) instead of
  /// the cropped equirectangular preview. File id refers to a
  /// project file (image of any aspect ratio).
  tourHeroFileId    String?
  /// Visual theme for the deck background + dividers. "space"
  /// turns on the animated starfield + planet drift; null/"light"
  /// keeps the neutral-50 baseline. Per-presentation so the
  /// architect can opt in selectively rather than apply
  /// site-wide.
  theme             String?
  /// When true, the 360° tour opens on the floor-plan room chooser
  /// (pick a room to start) instead of dropping straight into the
  /// starting panorama. Only takes effect when the deck actually has
  /// floor-plan rooms; otherwise it opens to the pano as usual.
  tourStartOnMap    Boolean                 @default(false)
  // Logical "rooms" pinned on a floor plan. Each room owns its own
  // marker position + name + which panorama is the entry point
  // ("starting pano"). Panoramas reference a room by id in their
  // metadata.roomId. Lets multiple panoramas share one map marker
  // (multi-shoot-point rooms) without a bidirectional sync
  // headache: editing the dot edits the ROOM, not whichever pano
  // happens to live in it. Shape: { rooms: TourRoom[] }.
  // Migration: when null/empty but per-pano metadata.floorPlan
  // exists, deriveTourRooms() builds an initial rooms list (one
  // room per legacy pano) on first save.
  tourRooms         Json?
  createdById       String
  createdBy         User                    @relation(fields: [createdById], references: [id])
  sections          PresentationSection[]
  accessLogs        PresentationAccessLog[]
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([accessToken])
  @@index([projectId])
  @@map("presentations")
}

model PresentationSection {
  id              String       @id @default(cuid())
  presentationId  String
  presentation    Presentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)
  type            String
  order           Int
  fileId          String?
  file            File?        @relation(fields: [fileId], references: [id], onDelete: SetNull)
  title           String?
  description     String?
  chapter         String?
  transitionStyle String?
  metadata        Json?
  createdAt       DateTime     @default(now())

  @@index([presentationId])
  @@map("presentation_sections")
}

model PresentationAccessLog {
  id              String       @id @default(cuid())
  presentationId  String
  presentation    Presentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)
  viewerEmail     String?
  viewerName      String?
  ipAddress       String?
  userAgent       String?
  viewedAt        DateTime     @default(now())

  @@index([presentationId])
  @@map("presentation_access_logs")
}
